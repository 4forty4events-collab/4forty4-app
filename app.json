{
  "expo": {
    "name": "Purday",
    "slug": "temp-app",
    "version": "1.0.0",
    "scheme": "fourty4",
    "orientation": "portrait",
    "icon": "./assets/brand/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.fourforty4events.app",
      "config": {
        "googleMapsApiKey": "AIzaSyAKJxJxQ8NN5KdwO6FKjmS97fuCyeFaaW8"
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.fourforty4events.app",
      "adaptiveIcon": {
        "backgroundColor": "#2E0355",
        "foregroundImage": "./assets/brand/app-icon.png",
        "backgroundImage": "./assets/brand/adaptive-background.png",
        "monochromeImage": "./assets/brand/adaptive-monochrome.png"
      },
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyAKJxJxQ8NN5KdwO6FKjmS97fuCyeFaaW8"
        }
      },
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/brand/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "0263aa59-9c94-43a3-96a0-dddc8b040f31"
      }
    },
    "owner": "4forty4_events",
    "plugins": [
      "expo-secure-store",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "image": "./assets/brand/logo-symbol.png",
          "imageWidth": 132,
          "resizeMode": "contain",
          "backgroundColor": "#0B1220"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Purday uses your location to show places and events near you on the map and sorted by distance."
        }
      ],
      "expo-notifications"
    ]
  }
}
